{
  "manifest_version": 3,
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {},
  "name": "Onlyfans Downloader Chrome",
  "short_name": "Onlyfans",
  "description": "Bulk download images and videos from my OnlyFans active subscriptions.",
  "version": "2.1.4",
  "key": "",
  "oauth2": {
    "client_id": "180346679292-785lr551chvrhjrs1lgj6te39b23kdpd.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "host_permissions": [
    "*://*.onlyfans.com/*",
    "*://r2.hlsdownloader.com/*",
    "*://hlsdownloader.com/*",
    "*://api.savemydayapp.com/*"
  ],
  "permissions": [
    "cookies",
    "storage",
    "identity",
    "scripting",
    "activeTab",
    "downloads"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://hlsdownloader.com/*"
    ]
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "js": [
        "assets/handleDL.ts-loader-C_TtAoSx.js"
      ],
      "matches": [
        "*://*.onlyfans.com/*"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.onlyfans.com/*"
      ],
      "resources": [
        "assets/icons/icon48.png",
        "assets/wasm/*",
        "assets/userStateBridge-DvAXSSjs.js",
        "assets/pageLeaveGuard-BNFWUG2B.js",
        "assets/onlyFansCookieAuth-QlPnLzuW.js",
        "assets/handleDL.ts-DB2NYKhI.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "homepage_url": "https://hlsdownloader.com"
}
